# OpenAI-compatible API (works with OpenAI, Ollama, LM Studio, vLLM, Groq, etc.)
#
# OpenAI (cloud):
#   OPENAI_API_KEY=sk-...
#   # OPENAI_BASE_URL=   (leave unset for official OpenAI)
#   OPENAI_MODEL=gpt-4o-mini
#
# Ollama (local):
#   OPENAI_API_KEY=ollama
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=llama3.1

OPENAI_API_KEY=your-api-key-or-ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=gpt-4o-mini
